# ─────────────────────────────────────────────
# Django core
# ─────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=your-droplet-ip,your-domain.com

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgres://bandboost_user:yourpassword@localhost:5432/bandboost_db

# ─────────────────────────────────────────────
# Redis (Celery broker + cache + rate limits)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# AI — Gemini (comma-separated for key rotation)
# ─────────────────────────────────────────────
GEMINI_API_KEYS=key1,key2,key3

# ─────────────────────────────────────────────
# AI — HuggingFace
# ─────────────────────────────────────────────
HF_API_TOKEN=hf_your_token_here

# ─────────────────────────────────────────────
# Auth — Supabase
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─────────────────────────────────────────────
# File Storage — DigitalOcean Spaces
# ─────────────────────────────────────────────
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=bandboost-uploads
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ─────────────────────────────────────────────
# Error Tracking — Sentry
# ─────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
DAILY_EVAL_LIMIT=5
RPM_LIMIT=10

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
