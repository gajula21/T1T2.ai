# ─────────────────────────────────────────────
# Next.js Frontend Environment Variables
# ─────────────────────────────────────────────

# URL of your Django backend (no trailing slash)
NEXT_PUBLIC_API_URL=https://your-droplet-ip-or-domain.com/api

# Supabase project settings (from supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Sentry (from sentry.io → Project → Client Keys)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
