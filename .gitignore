# ─────────────────────────────────────────────────────────
# BandBoost — root .gitignore
# ─────────────────────────────────────────────────────────

# ── Secrets / Environment ────────────────────────────────
.env
.env.local
.env.*.local
**/.env
**/.env.local

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
*.egg
.eggs/
pip-wheel-metadata/
*.pyo
*.pyd

# Django
backend/db.sqlite3
backend/staticfiles/
backend/media/
backend/*.log

# ── Node / Next.js ───────────────────────────────────────
node_modules/
frontend/.next/
frontend/out/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# ── Testing ──────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover
.tox/
.cache/

# ── IDEs ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Misc ─────────────────────────────────────────────────
*.log
*.tmp
*.bak
